@model ReniecRamos.Models.Citizen

<div class="container mt-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
            <h5 class="mb-0">Ficha de Identidad Institucional</h5>
            <span class="badge bg-primary">DNI: @Model.DocumentNumber</span>
        </div>
        <div class="card-body bg-light">
            <div class="row">
                <!-- Columna de la Foto -->
                <div class="col-md-3 text-center border-end">
                    <img src="~/uploads/citizens/@Model.ImagePath" class="img-thumbnail shadow-sm mb-3" style="width: 200px; height: 240px; object-fit: cover;" />
                    <div class="small fw-bold">ESTADO: @(Model.IsActive ? "VIGENTE" : "CADUCO")</div>
                </div>
                
                <!-- Datos Personales -->
                <div class="col-md-9 px-4">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <label class="text-muted small d-block">Apellidos y Nombres</label>
                            <h4 class="text-uppercase fw-bold">@Model.FirstLastName @Model.SecondLastName, @Model.FirstName</h4>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="text-muted small d-block">Fecha de Nacimiento</label>
                            <span>@Model.BirthDate.ToShortDateString()</span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="text-muted small d-block">Sexo</label>
                            <span>@(Model.Gender == "M" ? "Masculino" : "Femenino")</span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="text-muted small d-block">Estado Civil</label>
                            <span>@Model.CivilStatus?.Description</span>
                        </div>
                        <hr />
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small d-block">Lugar de Nacimiento</label>
                            <span class="small">@Model.BirthPlace?.Department - @Model.BirthPlace?.Province - @Model.BirthPlace?.District</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small d-block">Domicilio Actual</label>
                            <span class="small">@Model.CurrentAddress (@Model.ResidencePlace?.District)</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small d-block">Fecha de Emisión</label>
                            <span class="badge bg-secondary">@Model.IssueDate.ToShortDateString()</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small d-block">Fecha de Caducidad</label>
                            <span class="badge bg-danger">@Model.ExpiryDate.ToShortDateString()</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white text-end">
            <a asp-action="Index" class="btn btn-secondary btn-sm">Regresar</a>
            <a asp-action="Edit" asp-route-id="@Model.CitizenId" class="btn btn-warning btn-sm">Modificar Datos</a>
        </div>
    </div>
</div>