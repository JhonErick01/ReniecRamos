@model IEnumerable<ReniecRamos.Models.Citizen>

@{
    ViewData["Title"] = "Gestión de Ciudadanos";
}

<style>
    /* Estilos para que se vea más profesional y compacto */
    .table {
        font-size: 0.85rem; /* Letra más pequeña */
        vertical-align: middle;
    }
    .img-citizen {
        width: 40px;
        height: 40px;
        object-fit: cover;
        border-radius: 50%; /* Foto circular */
        border: 1px solid #dee2e6;
    }
    .badge {
        font-weight: 500;
        padding: 0.4em 0.6em;
    }
    .btn-action {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary fw-bold">Registro Nacional de Ciudadanos</h5>
            @if (User.IsInRole("Administrator"))
            {
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-lg"></i> Nuevo Registro
                </a>
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Foto</th>
                            <th>N° Documento</th>
                            <th>Nombres y Apellidos</th>
                            <th>Estado Civil</th>
                            <th>Residencia</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                    {
                                        <img src="~/uploads/citizens/@item.ImagePath" class="img-citizen" alt="Foto" />
                                    }
                                    else
                                    {
                                        <img src="~/img/default-user.png" class="img-citizen" alt="Sin foto" />
                                    }
                                </td>
                                <td class="fw-bold">@item.DocumentNumber</td>
                                <td>
                                    <span class="text-uppercase">@item.FirstLastName @item.SecondLastName</span>,
                                    <span class="text-capitalize text-muted">@item.FirstName</span>
                                </td>
                                <td>@item.CivilStatus?.Description</td>
                                <td>
                                    <small class="text-muted">@item.ResidencePlace?.District</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill @(item.IsActive ? "bg-success" : "bg-secondary")">
                                        @(item.IsActive ? "ACTIVO" : "INACTIVO")
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.CitizenId" class="btn btn-outline-info btn-action">Ver</a>
                                        @if (User.IsInRole("Administrator"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.CitizenId" class="btn btn-outline-warning btn-action">Editar</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-2">
            <small class="text-muted">Total de registros: @Model.Count()</small>
        </div>
    </div>
</div>