<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReniecRamos</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ReniecRamos.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <!-- Logo principal -->
                <a class="navbar-brand fw-bold text-primary" asp-controller="Citizens" asp-action="Index">ReniecRamos</a>
        
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <!-- Menú Izquierdo -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Citizens" asp-action="Index">
                                <i class="bi bi-people-fill"></i> Gestión de Ciudadanos
                            </a>
                        </li>
                    </ul>

                    <!-- Menú Derecho: Usuario y Logout -->
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <!-- Nombre del usuario con margen extra a la derecha (me-4) -->
                                <span class="navbar-text me-4 text-secondary">
                                    <i class="bi bi-person-circle"></i> Hola, <strong>@User.FindFirst("FullName")?.Value</strong>
                                </span>
                        
                                <!-- Botón de Logout bien alineado -->
                                <a class="btn btn-outline-danger btn-sm d-inline-flex align-items-center"
                                       asp-controller="Account" asp-action="Logout"
                                       style="height: fit-content;">
                                    <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Account" asp-action="Login">
                                    Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ReniecRamos - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
